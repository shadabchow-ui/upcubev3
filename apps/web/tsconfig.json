{
  "extends": [
    "@repo/typescript-config/nextjs.json"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@repo/*": ["../../packages/*"],
      "lib/*": ["./lib/*"],
      "components/*": ["./components/*"],
      "content/*": ["./content/*"],
      "md/*": ["./md/*"],
      "app/*": ["./app/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ]
}
